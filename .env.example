# Copy to .env and fill in your own keys. Do NOT commit .env.

# Model provider (the agent uses anthropic:claude-sonnet-4-6 via the LangSmith gateway)
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY_GATEWAY=

# Tavily web search
TAVILY_API_KEY=

# LangSmith: tracing + Prompt Hub (system prompt) + Context Hub (skills & memory).
# Use a key SCOPED TO THE WORKSPACE where these repos live — then it resolves its
# own tenant and you do NOT need LANGSMITH_WORKSPACE_ID. (An org/multi-workspace
# key resolves no tenant by default and 404s; set LANGSMITH_WORKSPACE_ID for those.)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=llm-research

# LangSmith resource identifiers (optional overrides for staging vs production).
# LLM_RESEARCH_PROMPT_NAME=llm-research-prompt
# LLM_RESEARCH_MEMORY_REPO=llm-research-memory
# LLM_RESEARCH_SKILLS=model-evaluation,benchmark-analysis,landscape-mapping,scorecard-maintenance,continuous-learning
